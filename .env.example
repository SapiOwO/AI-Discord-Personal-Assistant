# --- DISCORD AUTHENTICATION ---
# Get your token from https://discord.com/developers/applications
DISCORD_TOKEN=

# --- SECURITY & ACCESS CONTROL ---
# Separate multiple IDs with commas (e.g., 123456789,987654321)
OWNER_IDS=
TARGET_CHANNEL_IDS=
ALLOW_DMS=false

# --- SYSTEM PATHS ---
# Only change this if ffmpeg is not in your system PATH
FFMPEG_PATH=C:/Program Files/ffmpeg/bin/ffmpeg.exe

# --- GOOGLE PROGRAMMABLE SEARCH ---
# Optional: Setup at https://developers.google.com/custom-search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# --- MYSQL DATABASE ---
# Ensure your MySQL server is running before starting the bot
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=discord_ai