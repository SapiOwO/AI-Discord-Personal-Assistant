# --- DISCORD AUTHENTICATION ---
# Get your token from https://discord.com/developers/applications
DISCORD_TOKEN=

# --- SECURITY & ACCESS CONTROL ---
# Separate multiple IDs with commas (e.g., 123456789,987654321)
OWNER_IDS=
TARGET_CHANNEL_IDS=
ALLOW_DMS=false

# --- OLLAMA CORE SETTINGS ---
OLLAMA_HOST=http://localhost:11434
# Recommended: gemma4:e4b-it-q4_K_M or llama3
OLLAMA_MODEL=
OLLAMA_TIMEOUT=120

# --- MANUAL MODEL CAPABILITIES ---
# Enable based on your chosen model features
MODEL_SUPPORTS_VISION=true
MODEL_SUPPORTS_THINKING=false
MODEL_SUPPORTS_WEBSEARCH=true
MODEL_SUPPORTS_AUDIO=true

# --- DYNAMIC AI ENGINE ---
BURST_TYPING_MODE=True
# Separate trigger words with commas
TRIGGER_WORDS=bot,ai

# --- OLLAMA ADVANCED SETTINGS ---
OLLAMA_TEMPERATURE=0.7
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=8192

# --- TEXT-TO-SPEECH (TTS) SETTINGS ---
# Choose your TTS Engine: 'piper' (Lightweight, faster) or 'kokoro' (Studio-quality, ultra-realistic)
TTS_ENGINE=kokoro

# KOKORO VOICE SELECTION
# American Female: af_heart (Warm/Natural - DEFAULT), af_bella (Energetic), af_alloy (Professional), af_aoede (Husky), af_kore (Expressive)
# British Female: bf_emma (Elegant/BBC), bf_isabella (Casual), bf_alice (Soft/Calm)
TTS_VOICE=af_heart

# --- IMAGE PROCESSING & GENERATION ---
# Integration with Stable Diffusion WebUI (A1111/Forge)
STABLE_DIFFUSION_URL=http://127.0.0.1:7860
IMAGINE_COOLDOWN_SECONDS=60
IMAGE_MAX_DIMENSION=1024
IMAGE_COMPRESSION_QUALITY=85

# --- SYSTEM PATHS ---
# Path to ffmpeg.exe (Required for Music/Audio features)
FFMPEG_PATH=C:/Program Files/ffmpeg/bin/ffmpeg.exe
# Path to your preferred .ttf font for captioning
FONT_PATH=C:/Windows/Fonts/impact.ttf

# --- MUSIC BOT SETTINGS ---
INACTIVITY_TIMEOUT=60

# --- PRESENCE & FORMATTING ---
STATUS_MESSAGE=your heart
# Types: playing, streaming, listening, watching
STATUS_TYPE=listening
SHOW_FOOTER_INFO_DEFAULT=True

# --- AFK TIMER INTERVALS (Minutes) ---
# Initial delay before the first ping
AFK_MIN_MINUTES=15
AFK_MAX_MINUTES=60
# Delay for subsequent spam pings
AFK_FOLLOWUP_MIN_MINUTES=20
AFK_FOLLOWUP_MAX_MINUTES=180

# --- SLEEP & REMINDER SETTINGS (Hours) ---
# Delay for AI wake-up after user says "sleep/goodnight"
SLEEP_AFK_MIN_HOURS=7
SLEEP_AFK_MAX_HOURS=9

# --- PERSONA & ROLES ---
PERSONA_ALLOWED_ROLES=Admin,Moderator
DEFAULT_PERSONA="You are a helpful, elite AI assistant. Keep responses concise and direct."

# --- GOOGLE PROGRAMMABLE SEARCH ---
# Optional: Setup at https://developers.google.com/custom-search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_ALLOWED_DOMAINS=

# --- MYSQL DATABASE ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=discord_ai

# --- TUNABLES ---
# Number of web search results to inject into context
MAX_DOCS_PER_QUERY=8